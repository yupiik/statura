{
  "apiVersion": "v1",
  "kind": "Secret",
  "metadata": {
    "name": "registry-secret",
    "namespace": "{{namespace.name}}",
    "labels": {
      "app": "{{namespace.name}}-pull-secret",
      "deploy.by": "{{user.name:-unknown}}",
      "deploy.at": "{{deploytime:-unset}}",
      "environment": "{{environment:-unset}}"
    },
    "annotations": { "io.yupiik.bundlebee/putOnUpdate": "true" }
  },
  "type": "kubernetes.io/dockerconfigjson",
  "data": {
    ".dockerconfigjson": "{{bundlebee-base64:{{bundlebee-inline-file:{{maven.project.basedir}}/src/main/bundlebee/kubernetes/_templates/namespace/dockerconfig.json}} }}"
  }
}
