{
  "apiVersion": "v1",
  "kind": "Namespace",
  "metadata": {
    "name": "{{namespace.name}}",
    "labels": {
      "app.kubernetes.io/name": "{{namespace.name}}",
      "deploy.by": "{{user.name:-unknown}}",
      "deploy.at": "{{deploytime:-unset}}",
      "environment": "{{environment:-unset}}"
    }
  }
}
